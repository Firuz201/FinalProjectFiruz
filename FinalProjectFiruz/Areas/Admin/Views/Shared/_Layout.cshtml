@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/admin/assets/css/admin.css" />
    <!-- Feather icons CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/feather-icons/4.29.0/feather.min.js" defer></script>
    <script src="~/admin/assets/js/admin.js" defer></script>
</head>
<body>

    <div class="layout">

        <!-- ══════════════════════ SIDEBAR ══════════════════════ -->
        <aside class="sidebar">

            <div class="sidebar-brand">
                <div class="brand-icon"></div>
                <span class="brand-name">Glaci<span>ER</span></span>
            </div>

            <nav class="sidebar-nav">

                <a class="nav-item @(controller == "Dashboard" ? "active" : "")"
                   asp-area="Admin"
                   asp-controller="Dashboard"
                   asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
                    Dashboard
                </a>
                <a class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.5 7h13M7 13l-2-8M10 21a1 1 0 100-2 1 1 0 000 2zm7 0a1 1 0 100-2 1 1 0 000 2z" /></svg>
                    Orders
                </a>

                <a class="nav-item @(controller == "Product" ? "active" : "")"
                   asp-area="Admin"
                   asp-controller="Product"
                   asp-action="Index">
               
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" /></svg>
                    Products
                </a>
                <a class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 6h16M4 10h16M4 14h10" /></svg>
                    Categories
                </a>

                <a class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>
                    Customers
                </a>
                
                
                <a class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" /></svg>
                    Revenue
                </a>


            </nav>

            <div class="sidebar-footer">
                <div class="avatar">AD</div>
                <div class="user-info">
                    <div class="user-name">Admin User</div>
                    <div class="user-role">Super Admin</div>
                </div>
                <button class="icon-btn" style="margin-left:auto;width:28px;height:28px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" width="14" height="14"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                </button>
            </div>

        </aside>
        <!-- /sidebar -->
        <!-- ══════════════════════ MAIN ══════════════════════════ -->
        <div class="main">

            <!-- TOP BAR -->
            <header class="topbar">
                
                <span class="topbar-title">Admin panel</span>

                <form asp-action="Index" asp-controller="Home" asp-area="">
                <div style="text-align: right;">
                    <button class="btn-primary">
                        Back to Home Page
                    </button>
                </div>
                </form>
                @* <div class="topbar-search">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input type="text" placeholder="Search products, orders…" />
                </div>
                <div class="topbar-actions">
                    <button class="icon-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 01-3.46 0" /></svg>
                        <span class="dot"></span>
                    </button>
                    <button class="icon-bt1n">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" /></svg>
                    </button>
                    <div class="avatar" style="width:32px;height:32px;font-size:.72rem;cursor:pointer;">AD</div>
                </div> *@
            </header>
            <!-- /topbar -->
            @RenderBody()
            @RenderSection("Scripts", false)


</body>
</html>


            @* </div>
            <!-- content-wrapper ends -->
            <!-- partial:partials/_footer.html -->
            <footer class="footer">
                <div class="d-sm-flex justify-content-center justify-content-sm-between">
                    <span class="text-muted text-center text-sm-left d-block d-sm-inline-block">
                        Copyright © 2024 <a href="https://www.bootstrapdash.com/" target="_blank">Bootstrapdash</a>. All rights reserved.
                    </span>
                    <span class="float-none float-sm-end d-block mt-1 mt-sm-0 text-center">
                        Hand-crafted & made with <i class="mdi mdi-heart text-danger"></i>
                    </span>
                </div>
            </footer>
            <!-- partial -->
        </div>
        <!-- main-panel ends -->
    </div>
    <!-- page-body-wrapper ends -->
    </div>
    <!-- container-scroller -->
    <!-- plugins:js -->
    <script src="~/admin/assets/vendors/js/vendor.bundle.base.js"></script>
    <!-- endinject -->
    <!-- Plugin js for this page-->
    <script src="~/admin/assets/vendors/chart.js/chart.umd.js"></script>
    <script src="~/admin/assets/vendors/datatables.net/jquery.dataTables.js"></script>
    <script src="~/admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.js"></script>
    <!-- End plugin js for this page-->
    <!-- inject:js -->
    <script src="~/admin/assets/js/off-canvas.js"></script>
    <script src="~/admin/assets/js/hoverable-collapse.js"></script>
    <script src="~/admin/assets/js/template.js"></script>
    <script src="~/admin/assets/js/settings.js"></script>
    <script src="~/admin/assets/js/todolist.js"></script>
    <!-- endinject -->
    <!-- Custom js for this page-->
    <script src="~/admin/assets/js/dashboard.js"></script>
    <script src="~/admin/assets/js/proBanner.js"></script>

    <!-- End custom js for this page-->
    <script src="~/admin/assets/js/jquery.cookie.js" type="text/javascript"></script>

    @RenderSection("Scripts", false)
</body>

</html>

 *@
