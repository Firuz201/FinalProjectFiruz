@* @{
    Layout = null;
    ViewData["Title"] = "Admin — Shop Dashboard";
} *@


    <!-- PAGE CONTENT -->
    <main class="content">

      <!-- Page heading -->
      <div class="page-header fade-up">
        <div>
          <div class="page-title">Good morning, Admin</div>
          <div class="page-subtitle">Here's what's happening in your store today</div>
        </div>
        @* <div class="header-actions">
          <button class="btn-ghost">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export
          </button>
          <button class="btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Product
          </button>
        </div> *@
      </div>

      <!-- ── STAT CARDS ── -->
      <div class="stats-grid">

        <div class="stat-card fade-up delay-1">
          <div class="stat-label">Total Revenue</div>
          <div class="stat-value">$24,180</div>
          <div class="stat-meta up">↑ 12.4% vs last month</div>
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6"/></svg>
          </div>
        </div>

        <div class="stat-card fade-up delay-2">
          <div class="stat-label">Total Orders</div>
          <div class="stat-value">384</div>
          <div class="stat-meta up">↑ 8.1% vs last month</div>
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.5 7h13M10 21a1 1 0 100-2 1 1 0 000 2zm7 0a1 1 0 100-2 1 1 0 000 2z"/></svg>
          </div>
        </div>

        <div class="stat-card fade-up delay-3">
          <div class="stat-label">Products</div>
          <div class="stat-value">15</div>
          <div class="stat-meta">3 low stock</div>
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
          </div>
        </div>

        <div class="stat-card fade-up delay-4">
          <div class="stat-label">Customers</div>
          <div class="stat-value">1,204</div>
          <div class="stat-meta down">↓ 2.3% vs last month</div>
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
        </div>

      </div>
      <!-- /stats -->

      <!-- ── REVENUE CHART + TOP PRODUCTS ── -->
      <div class="grid-2 fade-up delay-2">

        <div class="panel">
          <div class="panel-header">
            <span class="panel-title">Revenue Overview</span>
            <div style="display:flex;gap:10px;align-items:center;">
              <div class="filter-pill active" style="padding:4px 10px;font-size:.65rem;">12W</div>
              <div class="filter-pill" style="padding:4px 10px;font-size:.65rem;">6M</div>
              <div class="filter-pill" style="padding:4px 10px;font-size:.65rem;">1Y</div>
            </div>
          </div>
          <div class="chart-legend">
            <div class="legend-item"><div class="legend-dot" style="background:#c8870a;"></div>Revenue</div>
            <div class="legend-item"><div class="legend-dot" style="background:#4a7a9b;"></div>Orders</div>
          </div>
          <div class="chart-wrap">
            <svg id="revenueChart" class="chart-svg" height="180"></svg>
          </div>
        </div>

        <div class="panel">
          <div class="panel-header">
            <span class="panel-title">Top Products</span>
            <span class="panel-action">View all →</span>
          </div>
          <div class="top-list">

            <div class="top-item">
              <div class="top-rank gold">1</div>
              <div class="top-thumb">
                <img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=80&h=80&fit=crop" alt="Armchair"/>
              </div>
              <div class="top-info">
                <div class="top-name">Armchair</div>
                <div class="top-sold">84 sold</div>
              </div>
              <div class="top-rev">$2,940</div>
            </div>

            <div class="top-item">
              <div class="top-rank" style="color:#888;">2</div>
              <div class="top-thumb">
                <img src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=80&h=80&fit=crop" alt="Black Armchair"/>
              </div>
              <div class="top-info">
                <div class="top-name">Black Armchair</div>
                <div class="top-sold">71 sold</div>
              </div>
              <div class="top-rev">$2,485</div>
            </div>

            <div class="top-item">
              <div class="top-rank" style="color:#888;">3</div>
              <div class="top-thumb">
                <img src="https://images.unsplash.com/photo-1567538096630-e0c55bd6374c?w=80&h=80&fit=crop" alt="Pillow"/>
              </div>
              <div class="top-info">
                <div class="top-name">Pillow</div>
                <div class="top-sold">60 sold</div>
              </div>
              <div class="top-rev">$2,100</div>
            </div>

            <div class="top-item">
              <div class="top-rank" style="color:#888;">4</div>
              <div class="top-thumb">
                <img src="https://images.unsplash.com/photo-1556228720-195a672e8a03?w=80&h=80&fit=crop" alt="Oak Tray"/>
              </div>
              <div class="top-info">
                <div class="top-name">Oak Tray</div>
                <div class="top-sold">52 sold</div>
              </div>
              <div class="top-rev">$1,820</div>
            </div>

            <div class="top-item">
              <div class="top-rank" style="color:#888;">5</div>
              <div class="top-thumb">
                <img src="https://images.unsplash.com/photo-1608515517025-c50b6f44e5f1?w=80&h=80&fit=crop" alt="Audio"/>
              </div>
              <div class="top-info">
                <div class="top-name">Audio Speaker</div>
                <div class="top-sold">200 sold</div>
              </div>
              <div class="top-rev">$1,800</div>
            </div>

          </div>
        </div>

      </div>
      <!-- /chart + top -->



      <!-- ── BOTTOM 3-COL ── -->
      <div class="grid-3 fade-up delay-3">

        <!-- Categories breakdown -->
        <div class="panel">
          <div class="panel-header">
            <span class="panel-title">Categories</span>
            <span class="panel-action">Manage →</span>
          </div>
          <div class="cat-list">
            <div class="cat-row">
              <div class="cat-row-head"><span class="cat-name">Furniture</span><span class="cat-pct">58%</span></div>
              <div class="cat-bar-bg"><div class="cat-bar-fill" data-width="58%" style="width:0;"></div></div>
            </div>
            <div class="cat-row">
              <div class="cat-row-head"><span class="cat-name">Audio</span><span class="cat-pct">22%</span></div>
              <div class="cat-bar-bg"><div class="cat-bar-fill" data-width="22%" style="width:0;background:linear-gradient(90deg,#4a7a9b,#6aaacb)"></div></div>
            </div>
            <div class="cat-row">
              <div class="cat-row-head"><span class="cat-name">Accessories</span><span class="cat-pct">13%</span></div>
              <div class="cat-bar-bg"><div class="cat-bar-fill" data-width="13%" style="width:0;background:linear-gradient(90deg,#7a6a4a,#a89060)"></div></div>
            </div>
            <div class="cat-row">
              <div class="cat-row-head"><span class="cat-name">Clothing</span><span class="cat-pct">7%</span></div>
              <div class="cat-bar-bg"><div class="cat-bar-fill" data-width="7%" style="width:0;background:linear-gradient(90deg,#4a6a4a,#6a9060)"></div></div>
            </div>
          </div>
        </div>

        <!-- Recent orders -->
        <div class="panel">
          <div class="panel-header">
            <span class="panel-title">Recent Orders</span>
            <span class="panel-action">View all →</span>
          </div>
          <div class="orders-feed">

            <div class="order-item">
              <div class="order-dot" style="background:#6dbe82;"></div>
              <div class="order-info">
                <div class="order-id">#ORD-8821</div>
                <div class="order-customer">Sarah K.</div>
              </div>
              <div>
                <div class="order-amount">$70.00</div>
                <div class="order-time">2 min ago</div>
              </div>
            </div>

            <div class="order-item">
              <div class="order-dot" style="background:var(--amber);"></div>
              <div class="order-info">
                <div class="order-id">#ORD-8820</div>
                <div class="order-customer">James R.</div>
              </div>
              <div>
                <div class="order-amount">$35.00</div>
                <div class="order-time">18 min ago</div>
              </div>
            </div>

            <div class="order-item">
              <div class="order-dot" style="background:#6dbe82;"></div>
              <div class="order-info">
                <div class="order-id">#ORD-8819</div>
                <div class="order-customer">Maria P.</div>
              </div>
              <div>
                <div class="order-amount">$9.00</div>
                <div class="order-time">34 min ago</div>
              </div>
            </div>

            <div class="order-item">
              <div class="order-dot" style="background:#e06060;"></div>
              <div class="order-info">
                <div class="order-id">#ORD-8818</div>
                <div class="order-customer">Tom W.</div>
              </div>
              <div>
                <div class="order-amount">$105.00</div>
                <div class="order-time">1 hr ago</div>
              </div>
            </div>

            <div class="order-item">
              <div class="order-dot" style="background:#6dbe82;"></div>
              <div class="order-info">
                <div class="order-id">#ORD-8817</div>
                <div class="order-customer">Ana L.</div>
              </div>
              <div>
                <div class="order-amount">$35.00</div>
                <div class="order-time">2 hr ago</div>
              </div>
            </div>

          </div>
        </div>

        <!-- Activity -->
        <div class="panel">
          <div class="panel-header">
            <span class="panel-title">Activity</span>
          </div>
          <div class="activity-feed">

            <div class="activity-item">
              <div class="act-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
              </div>
              <div class="act-body">
                <div class="act-text">New product <b>Lounge Chair</b> drafted</div>
                <div class="act-time">5 min ago</div>
              </div>
            </div>

            <div class="activity-item">
              <div class="act-icon" style="background:rgba(74,140,90,.15);color:#6dbe82;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4"/></svg>
              </div>
              <div class="act-body">
                <div class="act-text"><b>#ORD-8821</b> marked as fulfilled</div>
                <div class="act-time">12 min ago</div>
              </div>
            </div>

            <div class="activity-item">
              <div class="act-icon" style="background:rgba(192,64,64,.12);color:#e06060;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div class="act-body">
                <div class="act-text"><b>Oak Tray</b> is almost out of stock</div>
                <div class="act-time">1 hr ago</div>
              </div>
            </div>

            <div class="activity-item">
              <div class="act-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
              </div>
              <div class="act-body">
                <div class="act-text">New customer <b>Sarah K.</b> registered</div>
                <div class="act-time">2 hr ago</div>
              </div>
            </div>

            <div class="activity-item">
              <div class="act-icon" style="background:rgba(74,122,155,.15);color:#6aaccc;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/></svg>
              </div>
              <div class="act-body">
                <div class="act-text">Coupon <b>SUMMER20</b> created</div>
                <div class="act-time">3 hr ago</div>
              </div>
            </div>

          </div>
        </div>

      </div>
      <!-- /bottom grid -->

    </main>
    <!-- /content -->

  </div>
  <!-- /main -->

</div>
<!-- /layout -->

