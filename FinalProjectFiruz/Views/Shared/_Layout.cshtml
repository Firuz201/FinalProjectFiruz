                    <!-- logo -->
                    <div class="logo"><a href="index.html">GLACIER</a></div>
                    <!-- /logo -->
                    <!-- shop cart -->
                    <div class="cart-container">
                        <div class="icon-cart">
                            <i class="icon-ecommerce-bag"></i>
                        </div>
                        <div class="cart-widget">
                            <ul class="mini-cart cart_list product_list_widget">
                                @foreach (var item in basketItems)
                                {
                                    <li class="mini-cart-item">

                                        <!-- Кнопка удаления -->
                                        <a asp-action="RemoveFromBasket" asp-controller="Basket" asp-route-productId="@item.ProductId" class="remove-item">&times;</a>

                                        <a href="single-product.html">
                                            <img alt="@item.Product.Title" src="~/assets/images/@item.Product.ImagePath">
                                            @item.Product.Title
                                        </a>

                                        <span class="quantity">
                                            @item.Count ×
                                            <span>$@item.Product.Price</span>
                                        </span>
                                    </li>
                                }
                            </ul>
                            <p class="mini-cart__total total">
                                <strong>Subtotal:</strong>
                                <span>$@totalPrice</span>
                            </p> 
                            <p class="mini-cart__buttons buttons">
                                <a class="button" asp-action="Index" asp-controller="Basket">View cart</a>
                                <a class="button checkout" href="#">Checkout</a>
                            </p>
                        </div>
                    </div>
