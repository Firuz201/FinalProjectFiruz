@using FinalProjectFiruz.ViewModels.ProductViewModels
@model ProductGetVM

<!-- wrapper -->
<div id="wrapper">

    <div class="container">
        <div class="row">
            <div class="col-md-9">
                <div class="product-single-image">
                    <img alt="image" src="~/assets/images/@Model.ImagePath" />
                </div>

                <div class="product-single-info">
                <h3 class="product-single-title">@Model.Title</h3>
                <div class="star-rating">
                        <span style="width:@((Model.Rating/5.0)*100)%">
                            Rated <strong class="rating">@Model.Rating</strong> out of 5
                        </span>
                    </div>

                    <span class="shop-price">
                        <span>$</span>@Model.Price
                    </span>

                    <p>@Model.Description</p>

                    <form asp-action="AddToBasket" asp-controller="Basket" method="post">

                        <input type="hidden" name="productId" value="@Model.Id" />

                        <div class="shop-qty">
                            <button type="button" class="minus"></button>

                            <input type="number"
                                   step="1"
                                   min="1"
                                   max="50"
                                   name="count"
                                   value="1"
                                   class="qty">

                            <button type="button" class="plus"></button>
                        </div>

                        <button type="submit" class="button-product">
                            Add to cart
                        </button>

                    </form>

                </div>

                <div class="product-single-box">
                    <h2>DESCRIPTION</h2>
                    Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Vestibulum tortor quam, feugiat vitae, ultricies eget, tempor sit amet, ante. Donec eu libero sit amet quam egestas semper. Aenean ultricies mi vitae est. Mauris placerat eleifend leo.
                </div>

                <div class="product-related-products">
                    <h3 class="product-single-title">Related Products</h3>
                    <div class="shop-products shopContainer columns-3">
                        <div class="gutter-sizer"></div>

                        <!-- product 1 -->
                        <div class="product">
                            <a class="product-images" href="single-product.html">
                                <div class="shop-first-image">
                                    <img alt="image" src="~/assets/images/shop-product-1.jpg" />
                                </div>
                                <div class="shop-second-image">
                                    <img alt="image" src="~/assets/images/shop-product-1-2.jpg" />
                                </div>
                            </a>
                            <div class="shop-product-details">
                                <div class="shop-product-details-container">
                                    <h4 class="shop-product-title">
                                        <a href="single-product.html">Armchair</a>
                                    </h4>
                                    <div class="star-rating">
                                        <span style="width:80%">
                                            Rated
                                            <strong class="rating">4.00</strong>
                                            out of 5
                                        </span>
                                    </div>
                                    <span class="shop-price">
                                        <span>$</span>35.00
                                    </span>
                                    <div class="shop-button-box">
                                        <a class="button-product" href="#">Add to cart</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /product 1 -->
                        <!-- product 2 -->
                        <div class="product">
                            <a class="product-images" href="single-product.html">
                                <div class="shop-first-image">
                                    <img alt="image" src="~/assets/images/shop-product-2.jpg" />
                                </div>
                                <div class="shop-second-image">
                                    <img alt="image" src="~/assets/images/shop-product-2-2.jpg" />
                                </div>
                            </a>
                            <div class="shop-product-details">
                                <div class="shop-product-details-container">
                                    <h4 class="shop-product-title">
                                        <a href="single-product.html">Audio</a>
                                    </h4>
                                    <div class="star-rating">
                                        <span style="width:100%">
                                            Rated
                                            <strong class="rating">5.00</strong>
                                            out of 5
                                        </span>
                                    </div>
                                    <span class="shop-price">
                                        <span>$</span>9.00
                                    </span>
                                    <div class="shop-button-box">
                                        <a class="button-product" href="#">Add to cart</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /product 2 -->
                        <!-- product 3 -->
                        <div class="product">
                            <a class="product-images" href="single-product.html">
                                <div class="shop-first-image">
                                    <img alt="image" src="~/assets/images/shop-product-3.jpg" />
                                </div>
                                <div class="shop-second-image">
                                    <img alt="image" src="~/assets/images/shop-product-3-2.jpg" />
                                </div>
                            </a>
                            <div class="shop-product-details">
                                <div class="shop-product-details-container">
                                    <h4 class="shop-product-title">
                                        <a href="single-product.html">Black Armchair</a>
                                    </h4>
                                    <div class="star-rating">
                                        <span style="width:80%">
                                            Rated
                                            <strong class="rating">4.00</strong>
                                            out of 5
                                        </span>
                                    </div>
                                    <span class="shop-price">
                                        <span>$</span>35.00
                                    </span>
                                    <div class="shop-button-box">
                                        <a class="button-product" href="#">Add to cart</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /product 3 -->

                    </div>
                </div>

            </div>

            <div class="col-md-3 glacier-padding-left">
                <div class="sidebar">
                    <div class="sidebar-box">
                        <h1 class="sidebar-title">Product categories</h1>
                        <ul class="product-categories">
                            <li>
                                <a href="#">Albums</a>
                            </li>
                            <li>
                                <a href="#">Clothing</a>
                            </li>
                            <li>
                                <a href="#">Hoodies</a>
                            </li>
                            <li>
                                <a href="#">Music</a>
                            </li>
                            <li>
                                <a href="#">Posters</a>
                            </li>
                            <li>
                                <a href="#">Singles</a>
                            </li>
                            <li>
                                <a href="#">Uncategorized</a>
                            </li>
                        </ul>
                    </div>
                    <div class="sidebar-box">
                        <h1 class="sidebar-title">Top rated products</h1>
                        <ul class="sidebar-product-list">
                            <li>
                                <a href="single-product.html">
                                    <img alt="image" src="~/assets/images/sidebar-product-1.jpg" />
                                    <span class="product-title">Audio</span>
                                </a>
                                <div class="star-rating">
                                    <span style="width:100%">
                                        Rated
                                        <strong class="rating">5.00</strong>
                                        out of 5
                                    </span>
                                </div>
                                <span class="shop-price">
                                    <span>$</span>9.00
                                </span>
                            </li>
                            <li>
                                <a href="single-product.html">
                                    <img alt="image" src="~/assets/images/sidebar-product-2.jpg" />
                                    <span class="product-title">Pillow</span>
                                </a>
                                <div class="star-rating">
                                    <span style="width:93.4%">
                                        Rated
                                        <strong class="rating">4.67</strong>
                                        out of 5
                                    </span>
                                </div>
                                <span class="shop-price">
                                    <span>$</span>35.00
                                </span>
                            </li>
                            <li>
                                <a href="single-product.html">
                                    <img alt="image" src="~/assets/images/sidebar-product-3.jpg" />
                                    <span class="product-title">Oak Tray</span>
                                </a>
                                <div class="star-rating">
                                    <span style="width:90%">
                                        Rated
                                        <strong class="rating">4.50</strong>
                                        out of 5
                                    </span>
                                </div>
                                <span class="shop-price">
                                    <span>$</span>35.00
                                </span>
                            </li>
                            <li>
                                <a href="single-product.html">
                                    <img alt="image" src="~/assets/images/sidebar-product-4.jpg" />
                                    <span class="product-title">Bottle</span>
                                </a>
                                <div class="star-rating">
                                    <span style="width:90%">
                                        Rated
                                        <strong class="rating">4.50</strong>
                                        out of 5
                                    </span>
                                </div>
                                <del>
                                    <span class="shop-price">
                                        <span>$</span>3.00
                                    </span>
                                </del>
                                <ins>
                                    <span class="shop-price">
                                        <span>$</span>2.00
                                    </span>
                                </ins>
                            </li>
                            <li>
                                <a href="single-product.html">
                                    <img alt="image" src="~/assets/images/sidebar-product-5.jpg" />
                                    <span class="product-title">Vases</span>
                                </a>
                                <div class="star-rating">
                                    <span style="width:80%">
                                        Rated
                                        <strong class="rating">4.00</strong>
                                        out of 5
                                    </span>
                                </div>
                                <span class="shop-price">
                                    <span>$</span>3.00
                                </span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- /wrapper -->
