@using FinalProjectFiruz.ViewModels.HomeViewModels
@using FinalProjectFiruz.ViewModels.ProductViewModels
@model HomeVM
<!-- wrapper -->
<div id="wrapper">

    <!-- parallax -->
    <div class="parallax" style="background-image: url(assets/images/parallax-7.jpg);">
        <div class="info">
            <h2 data-in-effect="fadeIn">Glacier Shop</h2>
        </div>
    </div>
    <!-- /parallax -->

    <div style="margin-top: 60px; margin-bottom: 10px;">
        <div class="container">
            <div class="row">
                <div class="col-md-9">
                    <h1 class="page-title">Shop</h1>
                    
                    <form class="shop-ordering" method="get">
                        <select class="orderby" name="orderby">
                            <option selected='selected' value="menu_order">Default sorting</option>
                            <option value="popularity">Sort by popularity</option>
                            <option value="rating">Sort by average rating</option>
                            <option value="date">Sort by newness</option>
                            <option value="price">Sort by price: low to high</option>
                            <option value="price-desc">Sort by price: high to low</option>
                        </select>
                    </form>

                    <div id="grid-shop" class="cbp shop-products">

                        @foreach(var product in Model.Products)
                        {
                            <div class="cbp-item product">
                                <a class="product-images"
                                   asp-controller="ProductPage"
                                   asp-action="Detail"
                                   asp-route-id="@product.Id">
                                    <div class="shop-first-image" style="height:250px; display:flex; align-items:center; justify-content:center;">
                                        <img src="~/assets/images/@product.ImagePath"
                                             alt="image"
                                             style="max-height:100%; max-width:100%; object-fit:contain;" />
                                    </div>
                                    <div class="shop-second-image" style="height:250px; display:flex; align-items:center; justify-content:center;">
                                        <img src="~/assets/images/@product.SecondImagePath"
                                             alt="image"
                                             style="max-height:100%; max-width:100%; object-fit:contain;" />
                                    </div>
                                </a>
                                <div class="shop-product-details">
                                    <div class="shop-product-details-container">
                                        <h4 class="shop-product-title">
                                            <a asp-controller="ProductPage"
                                               asp-action="Detail"
                                               asp-route-id="@product.Id">
                                                @product.Title
                                            </a>
                                        </h4>
                                        <div class="star-rating">
                                            <span style="width:@((product.Rating / 5.0) * 100)%">
                                                Rated
                                                <strong class="rating">@product.Rating</strong>
                                                out of 5
                                            </span>
                                        </div>
                                        <span class="shop-price">
                                            <span>$</span>@product.Price
                                        </span>
                                        <div class="shop-button-box">
                                            <a asp-action="AddToBasket" asp-controller="Basket" asp-route-productId="@product.Id">Add to cart</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                       
                        
                    </div>

                    <!-- ajax load button -->
                    <div class="load-more text-center">
                        <a href="ajax-shop/shop-product.html" class="cbp-l-loadMore-link" rel="nofollow">
                            <span class="cbp-l-loadMore-defaultText">LOAD MORE</span>
                            <span class="cbp-l-loadMore-loadingText"><span class="glacier-spinner"><i></i></span>LOAD MORE</span>
                            <span class="cbp-l-loadMore-noMoreLoading">NO MORE</span>
                        </a>
                    </div>
                    <!-- /ajax load button -->

                </div>

                <div class="col-md-3 glacier-padding-left">
                    <div class="sidebar">
                        <div class="sidebar-box">
                            <h1 class="sidebar-title">Product categories</h1>
                            <ul class="product-categories">
                                @foreach (var category in Model.Categories)
                                {
                                    <li>
                                        <a asp-action="Index" asp-route-categoryId="@category.Id">
                                            @category.Name
                                        </a>
                                    </li>
                                }
                                
                                
                            </ul>
                        </div>
                        <div class="sidebar-box">
                            <h1 class="sidebar-title">Top rated products</h1>
                            <ul class="sidebar-product-list">
                                <li>
                                    <a href="single-product.html">
                                        <img alt="image" src="~/admin/assets/images/sidebar-product-1.jpg" />
                                        <span class="product-title">Audio</span>
                                    </a>
                                    <div class="star-rating">
                                        <span style="width:100%">
                                            Rated
                                            <strong class="rating">5.00</strong>
                                            out of 5
                                        </span>
                                    </div>
                                    <span class="shop-price">
                                        <span>$</span>9.00
                                    </span>
                                </li>
                                <li>
                                    <a href="single-product.html">
                                        <img alt="image" src="~/admin/assets/images/sidebar-product-2.jpg" />
                                        <span class="product-title">Pillow</span>
                                    </a>
                                    <div class="star-rating">
                                        <span style="width:93.4%">
                                            Rated
                                            <strong class="rating">4.67</strong>
                                            out of 5
                                        </span>
                                    </div>
                                    <span class="shop-price">
                                        <span>$</span>35.00
                                    </span>
                                </li>
                                <li>
                                    <a href="single-product.html">
                                        <img alt="image" src="~/admin/assets/images/sidebar-product-3.jpg" />
                                        <span class="product-title">Oak Tray</span>
                                    </a>
                                    <div class="star-rating">
                                        <span style="width:90%">
                                            Rated
                                            <strong class="rating">4.50</strong>
                                            out of 5
                                        </span>
                                    </div>
                                    <span class="shop-price">
                                        <span>$</span>35.00
                                    </span>
                                </li>
                                <li>
                                    <a href="single-product.html">
                                        <img alt="image" src="~/admin/assets/images/sidebar-product-4.jpg" />
                                        <span class="product-title">Bottle</span>
                                    </a>
                                    <div class="star-rating">
                                        <span style="width:90%">
                                            Rated
                                            <strong class="rating">4.50</strong>
                                            out of 5
                                        </span>
                                    </div>
                                    <del>
                                        <span class="shop-price">
                                            <span>$</span>3.00
                                        </span>
                                    </del>
                                    <ins>
                                        <span class="shop-price">
                                            <span>$</span>2.00
                                        </span>
                                    </ins>
                                </li>
                                <li>
                                    <a href="single-product.html">
                                        <img alt="image" src="~/admin/assets/images/sidebar-product-5.jpg" />
                                        <span class="product-title">Vases</span>
                                    </a>
                                    <div class="star-rating">
                                        <span style="width:80%">
                                            Rated
                                            <strong class="rating">4.00</strong>
                                            out of 5
                                        </span>
                                    </div>
                                    <span class="shop-price">
                                        <span>$</span>3.00
                                    </span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- /wrapper --> 