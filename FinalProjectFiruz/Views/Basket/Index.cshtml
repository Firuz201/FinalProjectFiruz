@using FinalProjectFiruz.Models
@* @using FinalProjectFiruz.ViewModels.BasketViewModels
 *@
 
@model List<BasketItem>

@* <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap');

    :root {
        --glacier-dark: #1a1e22;
        --glacier-mid: #2d3540;
        --glacier-ice: #d6e4ec;
        --glacier-frost: #f0f5f8;
        --glacier-accent: #7aabb8;
        --glacier-gold: #c4a35a;
        --glacier-text: #3a4550;
        --transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ── Page shell ── */
    .cart-page-wrapper {
        font-family: 'Jost', sans-serif;
        color: var(--glacier-text);
        background: var(--glacier-frost);
        min-height: 80vh;
    }

    /* ── Parallax banner ── */
    .cart-parallax {
        position: relative;
        height: 260px;
        background-image: url(assets/images/parallax-7.jpg);
        background-attachment: fixed;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .cart-parallax::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg, rgba(26,30,34,.65) 0%, rgba(122,171,184,.25) 100%);
        }

        .cart-parallax h2 {
            position: relative;
            font-family: 'Cormorant Garamond', serif;
            font-size: 3.2rem;
            font-weight: 300;
            letter-spacing: 0.18em;
            color: #fff;
            text-transform: uppercase;
            text-shadow: 0 2px 30px rgba(0,0,0,.4);
            margin: 0;
            animation: fadeInDown .9s ease both;
        }
    @keyframes fadeInDown {
        from

    {
        opacity: 0;
        transform: translateY(-24px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* ── Layout ── */
    .cart-section {
        padding: 70px 0 90px;
    }

        .cart-section .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

    /* ── Table ── */
    .cart-table-wrap {
        background: #fff;
        border-radius: 2px;
        box-shadow: 0 4px 40px rgba(26,30,34,.07);
        overflow: hidden;
    }

    .cart-table {
        width: 100%;
        border-collapse: collapse;
    }

        .cart-table thead tr {
            background: var(--glacier-dark);
        }

        .cart-table thead th {
            font-family: 'Jost', sans-serif;
            font-weight: 500;
            font-size: .72rem;
            letter-spacing: .16em;
            text-transform: uppercase;
            color: var(--glacier-ice);
            padding: 18px 22px;
            text-align: left;
        }

            .cart-table thead th.center {
                text-align: center;
            }

            .cart-table thead th.right {
                text-align: right;
            }

        .cart-table tbody tr {
            border-bottom: 1px solid #edf1f4;
            transition: var(--transition);
        }

            .cart-table tbody tr:last-child {
                border-bottom: none;
            }

            .cart-table tbody tr:hover {
                background: #f7fafb;
            }

        .cart-table td {
            padding: 22px 22px;
            vertical-align: middle;
        }

            .cart-table td.center {
                text-align: center;
            }

            .cart-table td.right {
                text-align: right;
            }

    /* product cell */
    .cart-product-cell {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .cart-product-img {
        width: 78px;
        height: 78px;
        object-fit: cover;
        border-radius: 2px;
        flex-shrink: 0;
        box-shadow: 0 2px 12px rgba(0,0,0,.10);
        transition: var(--transition);
    }

    .cart-table tbody tr:hover .cart-product-img {
        transform: scale(1.04);
    }

    .cart-product-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--glacier-dark);
        line-height: 1.3;
    }

    .cart-product-sub {
        font-size: .75rem;
        color: #9aacb5;
        letter-spacing: .06em;
        margin-top: 3px;
    }

    /* price */
    .cart-price {
        font-size: 1rem;
        font-weight: 500;
        color: var(--glacier-dark);
    }

        .cart-price .currency {
            font-size: .75rem;
            font-weight: 400;
            color: var(--glacier-accent);
            margin-right: 1px;
        }

    /* quantity */
    .qty-control {
        display: inline-flex;
        align-items: center;
        border: 1px solid #cdd8de;
        border-radius: 2px;
        overflow: hidden;
    }

    .qty-btn {
        width: 32px;
        height: 36px;
        background: var(--glacier-frost);
        border: none;
        cursor: pointer;
        font-size: 1rem;
        color: var(--glacier-mid);
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .qty-btn:hover {
            background: var(--glacier-accent);
            color: #fff;
        }

    .qty-input {
        width: 44px;
        height: 36px;
        border: none;
        border-left: 1px solid #cdd8de;
        border-right: 1px solid #cdd8de;
        text-align: center;
        font-family: 'Jost', sans-serif;
        font-size: .9rem;
        color: var(--glacier-dark);
        background: #fff;
    }

        .qty-input:focus {
            outline: none;
        }

    /* remove btn */
    .btn-remove {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1.5px solid #cdd8de;
        background: transparent;
        color: #b0bec5;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        font-size: .85rem;
    }

        .btn-remove:hover {
            border-color: #e57373;
            background: #fdecea;
            color: #e57373;
        }

    /* subtotal */
    .cart-subtotal {
        font-weight: 600;
        font-size: 1rem;
        color: var(--glacier-dark);
    }

        .cart-subtotal .currency {
            color: var(--glacier-gold);
            font-weight: 400;
            font-size: .78rem;
        }

    /* ── Bottom row ── */
    .cart-actions {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 40px;
        margin-top: 48px;
        flex-wrap: wrap;
    }

    /* coupon */
    .coupon-box {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

        .coupon-box label {
            font-size: .75rem;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: #8a9daa;
            margin-right: 4px;
        }

    .coupon-input {
        border: 1.5px solid #cdd8de;
        background: #fff;
        padding: 10px 16px;
        font-family: 'Jost', sans-serif;
        font-size: .88rem;
        color: var(--glacier-dark);
        border-radius: 2px;
        width: 200px;
        transition: var(--transition);
    }

        .coupon-input:focus {
            outline: none;
            border-color: var(--glacier-accent);
        }

        .coupon-input::placeholder {
            color: #b8cad3;
        }

    /* buttons */
    .btn-ghost {
        padding: 11px 26px;
        border: 1.5px solid var(--glacier-mid);
        background: transparent;
        font-family: 'Jost', sans-serif;
        font-size: .75rem;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--glacier-mid);
        cursor: pointer;
        border-radius: 2px;
        transition: var(--transition);
    }

        .btn-ghost:hover {
            background: var(--glacier-mid);
            color: #fff;
        }

    /* ── Order summary card ── */
    .order-summary {
        background: #fff;
        border-radius: 2px;
        box-shadow: 0 4px 40px rgba(26,30,34,.07);
        padding: 36px 34px 40px;
        min-width: 320px;
    }

        .order-summary h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.6rem;
            font-weight: 600;
            color: var(--glacier-dark);
            letter-spacing: .04em;
            margin: 0 0 26px;
            padding-bottom: 16px;
            border-bottom: 1px solid #e8eff3;
        }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 10px 0;
        font-size: .9rem;
    }

        .summary-row:not(:last-child) {
            border-bottom: 1px dashed #e8eff3;
        }

    .summary-label {
        color: #8a9daa;
        letter-spacing: .06em;
    }

    .summary-value {
        font-weight: 500;
        color: var(--glacier-dark);
    }

    .summary-row.total {
        margin-top: 8px;
        padding-top: 18px;
        border-top: 2px solid var(--glacier-dark) !important;
        border-bottom: none !important;
    }

        .summary-row.total .summary-label {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--glacier-dark);
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .summary-row.total .summary-value {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            color: var(--glacier-dark);
            font-weight: 600;
        }

            .summary-row.total .summary-value .currency {
                color: var(--glacier-gold);
                font-size: .9rem;
            }

    .btn-checkout {
        display: block;
        width: 100%;
        margin-top: 28px;
        padding: 15px;
        background: var(--glacier-dark);
        color: #fff;
        border: none;
        font-family: 'Jost', sans-serif;
        font-size: .8rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        cursor: pointer;
        border-radius: 2px;
        text-align: center;
        text-decoration: none;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

        .btn-checkout::after {
            content: '';
            position: absolute;
            inset: 0;
            background: var(--glacier-accent);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
            z-index: 0;
        }

        .btn-checkout:hover::after {
            transform: scaleX(1);
        }

        .btn-checkout span {
            position: relative;
            z-index: 1;
        }

    .btn-continue {
        display: block;
        width: 100%;
        margin-top: 12px;
        padding: 12px;
        background: transparent;
        color: #8a9daa;
        border: 1.5px solid #cdd8de;
        font-family: 'Jost', sans-serif;
        font-size: .75rem;
        letter-spacing: .14em;
        text-transform: uppercase;
        cursor: pointer;
        border-radius: 2px;
        text-align: center;
        text-decoration: none;
        transition: var(--transition);
    }

        .btn-continue:hover {
            border-color: var(--glacier-mid);
            color: var(--glacier-mid);
        }

    /* ── Empty state ── */
    .cart-empty {
        text-align: center;
        padding: 80px 20px;
    }

        .cart-empty svg {
            opacity: .25;
            margin-bottom: 24px;
        }

        .cart-empty h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 300;
            color: var(--glacier-mid);
            margin: 0 0 10px;
        }

        .cart-empty p {
            color: #9aacb5;
            font-size: .9rem;
            margin: 0 0 30px;
        }

    /* ── Responsive ── */
    @@media(max-width: 900px) {
        .cart-table thead {
            display: none;
        }

        .cart-table tbody tr {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            padding: 20px;
            position: relative;
        }

        .cart-table td {
            padding: 0;
            border: none;
        }

            .cart-table td.right, .cart-table td.center {
                text-align: left;
            }

        .cart-actions {
            flex-direction: column;
        }

        .order-summary {
            min-width: unset;
            width: 100%;
        }
    }

    @@media(max-width: 520px) {
        .cart-parallax h2 {
            font-size: 2rem;
        }

        .cart-table tbody tr {
            grid-template-columns: 1fr;
        }
    }
</style> *@

<div class="cart-page-wrapper">

    <!-- Banner -->
    <div class="cart-parallax">
        <h2>Your Cart</h2>
    </div>

    <div class="cart-section">
        <div class="container">

            @if (Model == null || !Model.Any())
            {
                <!-- Empty state -->
                <div class="cart-empty">
                    <svg width="90" height="90" viewBox="0 0 24 24" fill="none" stroke="#7aabb8" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1" />
                        <circle cx="20" cy="21" r="1" />
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                    </svg>
                    <h3>Your cart is empty</h3>
                    <p>Looks like you haven't added anything yet.</p>
                    <a href="@Url.Action("Index", "Shop")" class="btn-ghost">Continue Shopping</a>
                </div>
            }
            else
            {
                <!-- Cart table -->
                <div class="cart-table-wrap">
                    <table class="cart-table">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Product</th>
                                <th class="center">Quantity</th>
                                <th class="center">Unit Price</th>
                                <th class="right">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <!-- Remove -->
                                    <td style="width:52px;">
                                        <a asp-action="RemoveFromBasket" asp-controller="Basket" asp-route-id="@item.ProductId"
                                           class="btn-remove" title="Remove item">&#x2715;</a>
                                    </td>

                                    <!-- Product -->
                                    <td>
                                        <div class="cart-product-cell">
                                            <img class="cart-product-img"
                                                 src="~/assets/images/@item.Product.ImagePath"
                                                 alt="Cart Thumbnail" />
                                            <div>
                                                <div class="cart-product-name">@item.Product.Title</div>
                                                <div class="cart-product-sub">Glacier Shop</div>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Quantity -->
                                    <td class="center">
                                        <div class="qty-control">
                                            <button style="z-index:999" class="qty-btn decreaseBtn" data-productId="@item.ProductId" type="button"
                                                    onclick="changeQty(this, -1, '@item.Id')">
                                                &#8722;
                                            </button>
                                            <input class="qty-input" type="number"
                                                   value="@item.Count" min="1" max="99"
                                                   data-id="@item.Id" data-price="@item.Product.Price"
                                                   onchange="updateSubtotal(this)" />
                                            <button style="z-index:999" class="qty-btn increaseBtn" data-productId="@item.ProductId" type="button"
                                                    onclick="changeQty(this, 1, '@item.Id')">
                                                &#43;
                                            </button>
                                        </div>
                                    </td>

                                    <!-- Unit price -->
                                    <td class="center">
                                        <span class="cart-price">
                                            <span class="currency">$</span>@item.Product.Price.ToString("0.00")
                                        </span>
                                    </td>

                                    <!-- Subtotal -->
                                    <td class="right">
                                        <span class="cart-subtotal" id="sub-@item.Id">
                                            <span class="currency">$</span>
                                            @((item.Product.Price * item.Count).ToString("0.00"))
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Bottom actions -->
                <div class="cart-actions">

                    <!-- Left: coupon + update -->
                    <div>
                        <div class="coupon-box">
                            <label>Coupon</label>
                            <input class="coupon-input" type="text" placeholder="Enter code…" />
                            <button class="btn-ghost" type="button">Apply</button>
                        </div>
                    </div>

                    <!-- Right: order summary -->
                    <div class="order-summary">
                        <h3>Order Summary</h3>

                        @{
                            decimal subtotal = Model.Sum(i => i.Product.Price * i.Count);
                            decimal shipping = subtotal > 0 ? 9.99m : 0m;
                            decimal total = subtotal + shipping;
                        }

                        <div class="summary-row">
                            <span class="summary-label">Subtotal</span>
                            <span class="summary-value" id="cart-subtotal-display">
                                $@subtotal.ToString("0.00")
                            </span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">Shipping</span>
                            <span class="summary-value">$@shipping.ToString("0.00")</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">Tax (est.)</span>
                            <span class="summary-value">—</span>
                        </div>
                        <div class="summary-row total">
                            <span class="summary-label">Total</span>
                            <span class="summary-value" id="cart-total-display">
                                <span class="currency">$</span>@total.ToString("0.00")
                            </span>
                        </div>

                        <a asp-action="Checkout" asp-controller="Order" class="btn-checkout">
                            <span>Proceed to Checkout</span>
                        </a>
                        <a asp-action="Index" asp-controller="Shop" class="btn-continue">
                            Continue Shopping
                        </a>
                    </div>
                </div>
            }

        </div><!-- /container -->
    </div><!-- /cart-section -->
</div>

<script>
    function changeQty(btn, delta, id) {
        const row   = btn.closest('tr');
        const input = row.querySelector('.qty-input');
        let val = parseInt(input.value) + delta;
        if (val < 1) val = 1;
        if (val > 99) val = 99;
        input.value = val;
        updateSubtotal(input);
    }

    const increaseBtns = document.querySelectorAll(".increaseBtn");
    const decreaseBtns = document.querySelectorAll(".decreaseBtn");

    increaseBtns.forEach(btn => {
        btn.addEventListener('click', async (e) => {

            let productId = btn.getAttribute("data-productId");

            var response = await fetch(`/Basket/AddToBasket?productId=${productId}`)

            console.log(response);

        })
    })
    decreaseBtns.forEach(btn => {
        btn.addEventListener('click', async (e) => {
                let productId = btn.getAttribute("data-productId");

                var response = await fetch(`/Basket/DecreaseBasketItemCount?productId=${productId}`)

                console.log(response);        
        })
    })

    

    function updateSubtotal(input) {
        const id    = input.dataset.id;
        const price = parseFloat(input.dataset.price);
        const qty   = parseInt(input.value) || 1;
        const sub   = price * qty;

        const cell = document.getElementById('sub-' + id);
        if (cell) cell.innerHTML = '<span class="currency">$</span>' + sub.toFixed(2);

        recalcTotal();
    }

    function recalcTotal() {
        let subtotal = 0;
        document.querySelectorAll('.qty-input').forEach(inp => {
            subtotal += parseFloat(inp.dataset.price) * (parseInt(inp.value) || 1);
        });
        const shipping = subtotal > 0 ? 9.99 : 0;
        const total    = subtotal + shipping;

        const subEl = document.getElementById('cart-subtotal-display');
        const totEl = document.getElementById('cart-total-display');
        if (subEl) subEl.textContent = '$' + subtotal.toFixed(2);
        if (totEl) totEl.innerHTML   = '<span class="currency">$</span>' + total.toFixed(2);
    }
</script>


